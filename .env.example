# Runtime mode: paper or live. Live still requires all live gates below.
EXECUTION_MODE=paper
ALLOW_LIVE=false
CONFIRM_NON_RESTRICTED_LOCATION=false
REQUIRE_EXACT_RESOLUTION_SOURCE_FOR_LIVE=true
REQUIRE_API_AUTH=false
API_BEARER_TOKEN=

# Polymarket endpoints.
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_RTDS_URL=wss://ws-live-data.polymarket.com

# Optional live CLOB wallet settings.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER=
POLYMARKET_SIGNATURE_TYPE=1
ALLOW_EMERGENCY_ACCOUNT_CANCEL=false
ENABLE_LIVE_HEARTBEAT=true
LIVE_HEARTBEAT_INTERVAL_SECONDS=5
LIVE_HEARTBEAT_FAILURE_THRESHOLD=2

# Optional generic Chainlink-compatible reference endpoint. This is not enough
# for live BTC 15m trading unless it is the exact resolution-aligned stream.
CHAINLINK_BTC_USD_URL=
CHAINLINK_API_KEY=

# Exact Chainlink Data Streams BTC/USD source for Polymarket 15m markets.
# Public source page: https://data.chain.link/streams/btc-usd
# Product name: BTC/USD-RefPrice-DS-Premium-Global-003
# Public page currently shows only a shortened Feed ID ending in 75b8.
CHAINLINK_DATA_STREAMS_API_URL=https://api.dataengine.chain.link
CHAINLINK_DATA_STREAMS_API_KEY=
CHAINLINK_DATA_STREAMS_API_SECRET=
CHAINLINK_BTC_USD_FEED_ID=
CHAINLINK_BTC_USD_PRODUCT_URL=https://data.chain.link/streams/btc-usd
CHAINLINK_BTC_USD_PRODUCT_NAME=BTC/USD-RefPrice-DS-Premium-Global-003
CHAINLINK_BTC_USD_FEED_ID_SUFFIX=75b8

# Risk and strategy defaults.
ENABLE_POLYMARKET_RTDS_CHAINLINK=true
ENABLE_POLYMARKET_RTDS_BINANCE=true
REFERENCE_DIVERGENCE_PAUSE_THRESHOLD=0.0015
START_PRICE_CAPTURE_GRACE_SECONDS=5
BASE_ORDER_SIZE=5
MAX_ORDER_SIZE=5
MAX_POSITION_PER_MARKET=25
MAX_TOTAL_POSITION=100
MAX_DAILY_LOSS=50
ENABLE_TAKER_ORDERS=false
TAKER_MIN_EDGE=0.03
MAKER_MIN_EDGE=0.01
MAKER_MARGIN=0.015
MODEL_ERROR_BUFFER=0.01
FINAL_NO_TRADE_SECONDS=30
ORDER_TTL_SECONDS=10
PAPER_MAKER_FILL_POLICY=touch_after_quote_was_live
PAPER_ORDER_LIVE_AFTER_MS=250

# Azure deployment/runtime defaults.
RUN_BOT_ON_STARTUP=false
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_CONTAINER_NAME=bot-events
AZURE_STORAGE_TABLE_NAME=BotEventIndex
AZURE_EVENT_INDEX_TYPES=market,market_start_price,fair_value,decision,execution_report,feed_error,reference
AZURE_RECORDER_BATCH_MAX_EVENTS=1000
AZURE_RECORDER_BATCH_MAX_BYTES=524288
AZURE_RECORDER_FLUSH_INTERVAL_SECONDS=2
AZURE_RECORDER_QUEUE_MAX_EVENTS=100000
AZURE_RECORDER_FLUSH_RETRIES=3
